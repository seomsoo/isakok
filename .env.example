VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 관측 레이어 (스펙 11 — Observability). 미설정 시 해당 SDK는 조용히 비활성.
# 환경 판정 1순위. Vercel deployment별 명시: production / development
VITE_APP_ENV=development
# Sentry (웹 에러 추적). 환경별 DSN.
VITE_SENTRY_DSN=
# Sentry release. Vercel build env에서 isakok-web@$VERCEL_GIT_COMMIT_SHA로 주입(소스맵 업로드와 동일값).
VITE_SENTRY_RELEASE=
# PostHog 프로젝트 키. dev/prod 별도 프로젝트 키(US 리전).
VITE_POSTHOG_KEY=

# --- 빌드 전용 시크릿(클라이언트 미노출 — Vercel build env에만) ---
# Sentry 소스맵 업로드. 설정돼 있을 때만 vite build가 소스맵을 생성·업로드·삭제한다.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

{
  "name": "@moving/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "npx expo start --dev-client",
    "typecheck": "npx tsc --noEmit",
    "lint": "eslint .",
    "build:dev": "eas build --profile development --platform all",
    "build:preview": "eas build --profile preview --platform all",
    "android:reverse": "adb reverse tcp:5173 tcp:5173 && adb reverse tcp:8081 tcp:8081",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.11",
    "@expo/vector-icons": "^15.1.1",
    "@moving/shared": "workspace:*",
    "@react-native-community/netinfo": "~11.5.2",
    "expo": "~55.0.24",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.34",
    "expo-font": "~55.0.7",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-native": "~0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.0",
    "react-native-webview": "^13.16.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~55.0.21",
    "eslint": "^9.28.0",
    "globals": "^16.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
